{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"lib": [
			"ESNext",
			"DOM"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"~/*": [ "./src/*" ],
			"@calmdown/pyxis-dom": [ "./src/index.ts" ]
		},
		"skipLibCheck": true,
		"stripInternal": true,
		"strict": true,
		"target": "ESNext",
		"types": [],
		"verbatimModuleSyntax": true
	},
	"include": [
		"./src/**/*.ts"
	],
	"exclude": [
		"./src/jsx/inferred.ts"
	]
}
